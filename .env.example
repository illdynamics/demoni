# ── Required ──────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ── Model selection ───────────────────────────────────────────────────
# User-facing model names (the bridge maps to actual DeepSeek models):
#   v4-flash          → deepseek-v4-flash (non-thinking)
#   v4-flash-thinking → deepseek-v4-flash (thinking)
#   v4-pro            → deepseek-v4-pro (non-thinking)
#   v4-pro-thinking   → deepseek-v4-pro (thinking)
DEMONI_MODEL=v4-flash-thinking
# DEMONI_THINKING=enabled|disabled  (auto-derived from model)
DEMONI_REASONING_EFFORT=high

# ── Bridge ────────────────────────────────────────────────────────────
# DEMONI_BRIDGE_PORT=7654
# DEMONI_BRIDGE_HOST=127.0.0.1
# DEMONI_BRIDGE_LOCAL_API_KEY=demoni-local-placeholder

# ── Demoni paths ──────────────────────────────────────────────────────
# DEMONI_HOME=~/.demoni
# GEMINI_CLI_HOME=~/.demoni/gemini-cli-home

# ── Optional power-ups ────────────────────────────────────────────────
# BRAVE_API_KEY=your-brave-search-key
# UNSTRUCTURED_API_KEY=your-unstructured-key

# ── Debug ─────────────────────────────────────────────────────────────
# DEMONI_DEBUG=1
# DEMONI_STREAM_IDLE_TIMEOUT_MS=600000
# DEMONI_REQUEST_MAX_RETRIES=2
