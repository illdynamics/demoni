#!/usr/bin/env bash
set -Eeuo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
root="$(cd "${script_dir}/.." && pwd)"

# Dev mode: use tsx to run TypeScript directly
if [[ -f "${root}/src/cli.ts" ]]; then
  exec npx --prefix "${root}" tsx "${root}/src/cli.ts" "$@"
fi

# Production: use compiled CLI
exec node "${root}/dist/cli.js" "$@"
