#!/usr/bin/env bash
set -Eeuo pipefail
printf 'DEMONI_MODEL=%s\n' "${DEMONI_MODEL:-v4-flash-thinking}"
printf 'DEMONI_BRIDGE_HOST=%s\n' "${DEMONI_BRIDGE_HOST:-127.0.0.1}"
printf 'DEMONI_BRIDGE_PORT=%s\n' "${DEMONI_BRIDGE_PORT:-7654}"
printf 'DEMONI_HOME=%s\n' "${DEMONI_HOME:-$HOME/.demoni}"
if [ -n "${DEEPSEEK_API_KEY:-}" ]; then
  printf 'DEEPSEEK_API_KEY=<set (redacted)>\n'
else
  printf 'DEEPSEEK_API_KEY=<missing>\n'
fi
