#!/usr/bin/env bash
# ───────────────────────────────────────────────────────────────────
# Demoni Bootstrap — build, install, dev, test, and run
# ───────────────────────────────────────────────────────────────────
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="${HOME}/.config/demoni"
BIN_DIR="${HOME}/bin"
IMAGE_NAME="demoni"
# Read version from VERSION file at repo root
VERSION=$(cat "${SCRIPT_DIR}/VERSION" 2>/dev/null | tr -d "\n" | sed "s/^v//")
VERSION="${VERSION:-0.0.0}"
CONTAINER_ENGINE=""

# ── Colors ───────────────────────────────────────────────────────

BOLD="\033[1m"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
RESET="\033[0m"

info()  { echo -e "${GREEN}→${RESET} ${BOLD}$*${RESET}"; }
warn()  { echo -e "${YELLOW}⚠${RESET} $*"; }
error() { echo -e "${RED}✗${RESET} $*" >&2; exit 1; }

# ── Container engine detection ──────────────────────────────────

detect_engine() {
  if command -v podman &>/dev/null; then
    CONTAINER_ENGINE="podman"
  elif command -v docker &>/dev/null; then
    CONTAINER_ENGINE="docker"
  else
    error "Neither podman nor docker found. Install one to continue.\n  macOS:  brew install podman\n  Linux:  apt install podman  or  apt install docker.io"
  fi
}

image_exists() {
  ${CONTAINER_ENGINE} image inspect "${IMAGE_NAME}:latest" &>/dev/null 2>&1
}

# ═══════════════════════════════════════════════════════════════════
# SUBCOMMANDS
# ═══════════════════════════════════════════════════════════════════

# ── help ─────────────────────────────────────────────────────────

cmd_help() {
  echo "Demoni v${VERSION} — AI coding agent"
  echo ""
  echo "Usage:"
  echo "  ./demoni <command> [options]"
  echo ""
  echo "Bootstrap & system:"
  echo "  build              Build TypeScript source (bridge + CLI)"
  echo "  clean              Remove build artifacts (dist/)"
  echo "  install            Install demoni to ~/.config/demoni & ~/bin/demoni"
  echo "  image              Build the Docker/Podman container image"
  echo "  uninstall          Remove demoni from ~/.config/demoni & ~/bin/demoni"
  echo ""
  echo "Development:"
  echo "  dev [args...]      Run demoni directly via tsx (no build needed)"
  echo "  run [args...]      Alias for dev"
  echo "  lint               Typecheck all TypeScript"
  echo "  test               Run test suite"
  echo "  smoke              Quick smoke check (test + build + model catalog)"
  echo ""
  echo "Info:"
  echo "  version            Show version"
  echo "  models             List available models from the catalog"
  echo "  help               Show this help"
  echo ""
  echo "Quick start:"
  echo "  ./demoni install"
  echo "  export PATH=\"\${HOME}/bin:\${PATH}\""
  echo "  export DEEPSEEK_API_KEY=\"sk-...\""
  echo "  demoni --help"
}

# ── version ──────────────────────────────────────────────────────

cmd_version() {
  echo "v${VERSION}"
}

# ── models ───────────────────────────────────────────────────────

cmd_models() {
  if [[ -f "${SCRIPT_DIR}/bridge/dist/types.js" ]]; then
    node -e "
    const {MODEL_CATALOG} = require('${SCRIPT_DIR}/bridge/dist/types.js');
    MODEL_CATALOG.forEach(m => console.log(m.id.padEnd(22), m.displayName, m.thinking ? '(thinking)' : ''));
    "
  else
    error "Bridge not built. Run: ./demoni build"
  fi
}

# ── build (TypeScript) ──────────────────────────────────────────

cmd_build() {
  info "Building bridge..."
  (cd "${SCRIPT_DIR}/bridge" && npx tsc)
  info "Building CLI..."
  (cd "${SCRIPT_DIR}" && npx tsc -p tsconfig.json)
  info "Build complete"
}

# ── clean ────────────────────────────────────────────────────────

cmd_clean() {
  info "Cleaning dist directories..."
  rm -rf "${SCRIPT_DIR}/dist" "${SCRIPT_DIR}/bridge/dist"
  info "Clean complete"
}

# ── lint / typecheck ─────────────────────────────────────────────

cmd_lint() {
  info "Typechecking CLI..."
  (cd "${SCRIPT_DIR}" && npx tsc -p tsconfig.json --noEmit)
  info "Typechecking bridge..."
  (cd "${SCRIPT_DIR}/bridge" && npx tsc --noEmit)
  info "All typechecks passed"
}

# ── test ─────────────────────────────────────────────────────────

cmd_test() {
  info "Running tests..."
  (cd "${SCRIPT_DIR}" && npx vitest run)
}

# ── dev (run via tsx) ────────────────────────────────────────────

cmd_dev() {
  if [[ ! -f "${SCRIPT_DIR}/src/cli.ts" ]]; then
    error "src/cli.ts not found. Are you in the repo root?"
  fi
  exec npx --prefix "${SCRIPT_DIR}" tsx "${SCRIPT_DIR}/src/cli.ts" "$@"
}

# ── image (container build) ──────────────────────────────────────

cmd_image() {
  detect_engine
  info "Building Demoni v${VERSION} ${CONTAINER_ENGINE} image..."
  (cd "${SCRIPT_DIR}" && ${CONTAINER_ENGINE} build -t "${IMAGE_NAME}:latest" -t "${IMAGE_NAME}:v${VERSION}" .)
  info "Image built successfully (demoni:latest, demoni:v${VERSION})"
}

# ── install ──────────────────────────────────────────────────────

cmd_install() {
  detect_engine

  # ── Check for Gemini CLI ────────────────────────────────────

  info "Checking for Gemini CLI..."

  GEMINI_FOUND=false
  if command -v gemini &>/dev/null; then
    GEMINI_FOUND=true
    echo "  ✓ gemini CLI found: $(which gemini)"
  elif command -v gemini-cli &>/dev/null; then
    GEMINI_FOUND=true
    echo "  ✓ gemini CLI found: $(which gemini-cli)"
  fi

  if [[ "${GEMINI_FOUND}" == "false" ]]; then
    echo "  → gemini CLI not found. Installing @google/gemini-cli globally..."
    if command -v npm &>/dev/null; then
      npm install -g @google/gemini-cli || {
        error "npm install failed. Install manually: npm install -g @google/gemini-cli"
      }
      echo "  ✓ @google/gemini-cli installed"
    else
      error "npm not found. Install Node.js and npm first, then: npm install -g @google/gemini-cli"
    fi
  fi

  # Build image if not present
  if ! image_exists; then
    info "Image not found, building first..."
    echo ""
    cmd_image
    echo ""
  fi

  # ── Create ~/.config/demoni ──────────────────────────────────

  mkdir -p "${CONFIG_DIR}"

  cat > "${CONFIG_DIR}/version.json" << EOF
{
  "version": "${VERSION}",
  "installed_at": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "install_method": "bootstrap"
}
EOF

  if [[ ! -f "${CONFIG_DIR}/installation_id" ]]; then
    uuidgen 2>/dev/null > "${CONFIG_DIR}/installation_id" || \
      cat /dev/urandom | LC_ALL=C tr -dc 'a-f0-9' | head -c 8 > "${CONFIG_DIR}/installation_id"
  fi

  mkdir -p "${CONFIG_DIR}/config"
  cp "${SCRIPT_DIR}/config/model-catalog.json" "${CONFIG_DIR}/config/"

  mkdir -p "${CONFIG_DIR}/log"
  mkdir -p "${CONFIG_DIR}/run"
  mkdir -p "${CONFIG_DIR}/gemini-cli-home"

  # ── Create ~/bin/demoni wrapper ──────────────────────────────

  mkdir -p "${BIN_DIR}"

  cat > "${BIN_DIR}/demoni" << 'WRAPPER_EOF'
#!/usr/bin/env bash
# Demoni — AI coding agent (containerized)
set -euo pipefail

CONFIG_DIR="${HOME}/.config/demoni"
IMAGE_NAME="demoni"
CONTAINER_ENGINE=""

if command -v podman &>/dev/null; then
  CONTAINER_ENGINE="podman"
elif command -v docker &>/dev/null; then
  CONTAINER_ENGINE="docker"
else
  echo "✗ Neither podman nor docker found." >&2
  exit 1
fi

if ! ${CONTAINER_ENGINE} image inspect "${IMAGE_NAME}:latest" &>/dev/null 2>&1; then
  echo "✗ Demoni image not found. Run './demoni install' from the repo first." >&2
  exit 1
fi

mkdir -p "${CONFIG_DIR}/log" "${CONFIG_DIR}/run" "${CONFIG_DIR}/gemini-cli-home"

exec ${CONTAINER_ENGINE} run --rm -i \
  ${DEEPSEEK_API_KEY:+-e DEEPSEEK_API_KEY="${DEEPSEEK_API_KEY}"} \
  ${DEMONI_MODEL:+-e DEMONI_MODEL="${DEMONI_MODEL}"} \
  ${DEMONI_REASONING_EFFORT:+-e DEMONI_REASONING_EFFORT="${DEMONI_REASONING_EFFORT}"} \
  -v "${PWD}:/workspace" \
  -v "${CONFIG_DIR}:/home/demoni/.demoni" \
  "${IMAGE_NAME}:latest" \
  "$@"
WRAPPER_EOF

  chmod +x "${BIN_DIR}/demoni"

  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  ✓ Demoni v${VERSION} installed successfully!              ║"
  echo "╠══════════════════════════════════════════════════════════════╣"
  echo "║  Config:  ${CONFIG_DIR}"
  echo "║  Binary:  ${BIN_DIR}/demoni"
  echo "╠══════════════════════════════════════════════════════════════╣"
  echo "║  Make sure ~/bin is in your PATH:                           ║"
  echo "║    export PATH=\"\${HOME}/bin:\${PATH}\"                   ║"
  echo "║                                                              ║"
  echo "║  Set your DeepSeek API key:                                  ║"
  echo "║    export DEEPSEEK_API_KEY=\"sk-...\"                        ║"
  echo "║                                                              ║"
  echo "║  Then run:                                                   ║"
  echo "║    demoni --help                                             ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""

  if [[ ":${PATH}:" != *":${BIN_DIR}:"* ]]; then
    warn "~/bin is NOT in your current PATH."
    echo "   Add this to your ~/.zshrc or ~/.bashrc:"
    echo ""
    echo "     export PATH=\"\${HOME}/bin:\${PATH}\""
    echo ""
  fi
}

# ── uninstall ────────────────────────────────────────────────────

cmd_uninstall() {
  info "Removing Demoni..."
  rm -f "${BIN_DIR}/demoni"
  rm -rf "${CONFIG_DIR}"
  echo "✓ Demoni uninstalled."
  echo "  To also remove the container image:"
  echo "    ${CONTAINER_ENGINE:-docker} rmi demoni:latest demoni:v${VERSION}"
}

# ── smoke ────────────────────────────────────────────────────────

cmd_smoke() {
  echo "=== Model catalog ==="
  if [[ -f "${SCRIPT_DIR}/bridge/dist/types.js" ]]; then
    node -e "
    import('${SCRIPT_DIR}/bridge/dist/types.js').then(t => {
      t.MODEL_CATALOG.forEach(m => console.log('  ' + m.id + ' → ' + m.providerModel, m.thinking ? '(thinking)' : ''));
    });
    "
  else
    warn "Bridge not built — skipping model catalog"
  fi
  echo ""
  echo "=== Tests ==="
  (cd "${SCRIPT_DIR}" && npx vitest run)
  echo ""
  echo "=== Build ==="
  echo "Bridge: $(ls "${SCRIPT_DIR}/bridge/dist/"*.js 2>/dev/null | wc -l) files"
  echo "CLI:    $(ls "${SCRIPT_DIR}/dist/"*.js 2>/dev/null | wc -l) files"
  echo ""
  echo "✓ smoke check passed"
}

# ═══════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════

case "${1:-}" in
  build)
    cmd_build
    ;;
  clean)
    cmd_clean
    ;;
  dev|run)
    shift
    cmd_dev "$@"
    ;;
  help|-h|--help)
    cmd_help
    ;;
  image)
    cmd_image
    ;;
  install)
    cmd_install
    ;;
  lint|typecheck)
    cmd_lint
    ;;
  models)
    cmd_models
    ;;
  smoke)
    cmd_smoke
    ;;
  test)
    cmd_test
    ;;
  uninstall)
    cmd_uninstall
    ;;
  version|--version)
    cmd_version
    ;;
  *)
    if [[ $# -eq 0 ]]; then
      cmd_help
    else
      error "Unknown command: $1\nRun ./demoni help for usage."
    fi
    ;;
esac
